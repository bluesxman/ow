{
  "name": "ow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "(MIT AND CC-BY-SA-3.0)",
  "description": "Overwatch hero data pipeline — scrapes Blizzard's hero pages and Fandom's wiki to publish JSON for Claude.ai conversations.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "scrape": "tsx src/index.ts",
    "scrape:dry": "tsx src/index.ts --dry-run",
    "scrape:dev": "tsx src/index.ts --dry-run --cache",
    "cache:clear": "tsx scripts/clear-cache.ts",
    "validate-published": "tsx scripts/validate-published.ts",
    "probe:fandom": "tsx scripts/probe-fandom.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "patch-notes:rebuild-aggregates": "tsx .claude/skills/process-patch-notes/scripts/rebuild-aggregates.ts",
    "patch-notes:dump-raw": "tsx .claude/skills/refresh-patch-notes/scripts/dump-raw-patches.ts",
    "patch-notes:validate": "tsx .claude/skills/refresh-patch-notes/scripts/validate-patch-notes.ts"
  },
  "dependencies": {
    "playwright": "^1.59.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.0",
    "eslint": "^9.39.4",
    "node-html-parser": "^7.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.0"
  }
}
